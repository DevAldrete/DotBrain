# Server Configuration
PORT=8080
ENV=development

# Database Configuration
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://dotbrain_user:dotbrain_pass@localhost:5432/dotbrain_db?sslmode=disable

# Security
# Set this to a secure random string for signing tokens, etc.
SECRET_KEY=your-super-secret-key-change-in-production

# AI / External Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
